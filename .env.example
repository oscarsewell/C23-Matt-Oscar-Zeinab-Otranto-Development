# AWS Config
AWS_REGION=eu-west-2

# DynamoDB
DYNAMODB_TABLE_NAME=table_name

# S3
S3_CACHE_BUCKET=bucket_name

# RSS Feeds
RSS_FEED_URL_1=https://example.com/feed1.xml
RSS_FEED_URL_2=https://example.com/feed2.xml

# LLM
LLM_PROVIDER=provider_name
LLM_API_KEY=api_key
LLM_MODEL=model_name

# Bluesky
BLUESKY_HANDLE=handle
BLUESKY_APP_PASSWORD=password